extends ../layouts/default.pug
include ../mixins/pagination.pug

block main 
  .row
    .col-12
      .card
        .card-header
          .row.align-items-center
            .col
              h4.card-title #{pageTitle}
            // end col
            .col-auto
              a.btn.btn-danger.me-1(
                href=`/${pathAdmin}/article/trash`
                )
                i.fa-solid.fa-trash.me-1
                | Thùng rác
              a.btn.btn-primary(
                href=`/${pathAdmin}/article/create`
                )
                i.fa-solid.fa-plus.me-1
                | Tạo bài viết
            // end col
          // end row
        // end card-header
        // Search
        .card-body.pt-0
          .row
            .col-lg-12
              include ../partials/form-search.pug
        // Table
        .table-responsive
          table.table.table-striped.mb-0
            thead.table-light
              tr
                th STT
                th Avatar
                th Tên bài viết
                th Trạng thái
                th Lượt xem
                th.text-end Hành động
            tbody
              if(allArticle.length > 0)
                each item, index in allArticle
                  tr
                    td #{pagination.skip + index + 1}
                    td 
                      if(item.avatar)
                        img(
                          src=`${domainFileManager}${item.avatar}`
                          class="thumb-md me-1 d-inline rounded"
                        )
                    td #{item.name}
                    td
                      if (item.status == "draft")
                        span.badge.bg-danger Bản nháp
                      else if (item.status == "published")
                        span.badge.bg-success Đã xuất bản
                      else if (item.status == "archived")
                        span.badge.bg-dark Đã lưu trữ
                    td #{item.view}
                    td.text-end
                      a(
                        href=`/${pathAdmin}/article/edit/${item.id}` 
                        style="margin: 5px" 
                        title="Chỉnh sửa"
                      )
                        <i class="fa-solid fa-pen-to-square text-secondary" style="font-size: 1.2rem;"></i>
                      a(
                        href="javascript:;" 
                        button-api 
                        data-method="PATCH"
                        data-api=`/${pathAdmin}/article/delete/${item.id}`
                        style="margin: 5px"
                        title="Xoá"
                      )
                        <i class="fa-solid fa-trash text-secondary" style="font-size: 1.2rem;"></i>
              else 
                tr
                  td(colspan=6 class="text-center") Không tìm thấy dữ liệu
          +pagination(pagination, page)
    // end col
  // end row